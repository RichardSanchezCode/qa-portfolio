    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains generated id\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains correct name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.name).to.eql(\"Richard Sanchez\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains correct email\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.email).to.eql(\"richard@example.com\");\r",
              "}); \r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set(\"userId\", jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
