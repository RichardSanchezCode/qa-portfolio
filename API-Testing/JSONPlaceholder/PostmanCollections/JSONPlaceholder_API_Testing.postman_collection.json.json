    {
      "name": "Get User by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.name).to.eql(\"Leanne Graham\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains email\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.email).to.eql(\"Sincere@april.biz\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains id\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(1);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
